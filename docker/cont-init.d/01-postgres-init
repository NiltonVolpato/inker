#!/bin/sh
set -e

if [ "$DB_PROVIDER" != "postgresql" ]; then
  echo "[init] PostgreSQL disabled, skipping init..."
  exit 0
fi

PGDATA=/var/lib/postgresql/17/main
PG17_BIN=/usr/lib/postgresql/17/bin

if [ -f "$PGDATA/PG_VERSION" ]; then
    PG_VER=$(cat "$PGDATA/PG_VERSION")

    if [ "$PG_VER" = "15" ]; then
        echo "[init] ERROR: PostgreSQL 15 data detected. Direct migration from PG15 to this image is not supported."
        echo "[init] Please migrate to PG17 first using a PG17-based image before switching to this image."
        exit 1
    else
        echo "[init] PostgreSQL data directory exists (version $PG_VER), skipping init"
        chown -R postgres:postgres /var/lib/postgresql
    fi
else
    echo "[init] Initializing PostgreSQL database..."
    mkdir -p "$PGDATA"
    chown -R postgres:postgres /var/lib/postgresql

    su - postgres -c "$PG17_BIN/initdb -D $PGDATA"

    cat > "$PGDATA/pg_hba.conf" <<'CONF'
local all postgres peer
local all all md5
host all all 127.0.0.1/32 md5
host all all ::1/128 md5
CONF

    su - postgres -c "$PG17_BIN/pg_ctl -D $PGDATA -w start"
    su - postgres -c "$PG17_BIN/psql -c \"CREATE USER inker_user WITH PASSWORD '${POSTGRES_PASSWORD:-inker_password}';\""
    su - postgres -c "$PG17_BIN/psql -c \"CREATE DATABASE inker_db OWNER inker_user;\""
    su - postgres -c "$PG17_BIN/pg_ctl -D $PGDATA -w stop"

    echo "[init] PostgreSQL initialized successfully"
fi
